# ---- Crypto Intelligence Terminal - backend config ----

# Symbols (Binance Futures format)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Refresh interval (seconds) for the aggregation loop
REFRESH_INTERVAL=5

# History size kept in memory for normalization windows
HISTORY_SIZE=720

# CORS (use * to allow all, or comma-separate origins)
CORS_ORIGINS=*

# Root path - set when backend is behind a reverse proxy at a sub-path
# e.g. for platform routing at /_/backend, set ROOT_PATH=/_/backend
ROOT_PATH=

# Optional - paid providers. Stubs work without these.
COINGECKO_API_KEY=
ARKHAM_API_KEY=
DEXSCREENER_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
